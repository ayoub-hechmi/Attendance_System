# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://attendance_user:change_me@localhost:5432/attendance_db

# Redis (used by Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Service URLs
AI_WORKER_URL=http://localhost:8001
BACKEND_URL=http://localhost:8000

# JWT auth
SECRET_KEY=change_me_use_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Face recognition
FACE_SIMILARITY_THRESHOLD=0.80
ATTENDANCE_WINDOW_MINUTES=3
